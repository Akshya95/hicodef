{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "slug": "primary",       "color": "#1a6b4a", "name": "Primary Green" },
        { "slug": "primary-light", "color": "#2d9b6e", "name": "Primary Light" },
        { "slug": "accent",        "color": "#f4a926", "name": "Accent Gold" },
        { "slug": "dark",          "color": "#1c1c1c", "name": "Dark" },
        { "slug": "mid",           "color": "#555555", "name": "Mid Grey" },
        { "slug": "light",         "color": "#f7f5f2", "name": "Light Background" },
        { "slug": "white",         "color": "#ffffff", "name": "White" }
      ],
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'DM Serif Display', Georgia, serif",
          "name": "DM Serif Display",
          "slug": "heading"
        },
        {
          "fontFamily": "'DM Sans', 'Helvetica Neue', sans-serif",
          "name": "DM Sans",
          "slug": "body"
        }
      ],
      "fontSizes": [
        { "slug": "small",   "size": "0.875rem", "name": "Small"   },
        { "slug": "normal",  "size": "1rem",     "name": "Normal"  },
        { "slug": "medium",  "size": "1.25rem",  "name": "Medium"  },
        { "slug": "large",   "size": "1.75rem",  "name": "Large"   },
        { "slug": "x-large", "size": "2.5rem",   "name": "X-Large" },
        { "slug": "huge",    "size": "3.5rem",   "name": "Huge"    }
      ],
      "customFontSize": true,
      "lineHeight": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "%", "vw"]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1180px"
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": true,
          "text": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#1c1c1c"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "1rem",
      "lineHeight": "1.75"
    },
    "elements": {
      "link": {
        "color": { "text": "#1a6b4a" },
        ":hover": {
          "color": { "text": "#2d9b6e" }
        }
      },
      "h1": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)" } },
      "h2": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)" } },
      "h3": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)" } },
      "h4": { "typography": { "fontFamily": "var(--wp--preset--font-family--heading)" } },
      "button": {
        "color": {
          "background": "#1a6b4a",
          "text": "#ffffff"
        },
        "border": { "radius": "6px" },
        ":hover": {
          "color": { "background": "#2d9b6e" }
        }
      }
    }
  }
}
